rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        request.auth.token.email_verified == true && (
          request.auth.token.email.lower() == "grafiqo.np@gmail.com" ||
          request.auth.token.email == "grafiqo.np@gmail.com" ||
          request.auth.token.email.lower() == "simplex.ktm@gmail.com" ||
          request.auth.token.email == "simplex.ktm@gmail.com"
        );
    }
  }
}
